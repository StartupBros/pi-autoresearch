{
  "name": "pi-autoresearch",
  "version": "1.4.0",
  "type": "module",
  "description": "Autonomous experiment loop for pi — run, measure, keep or discard. Inspired by karpathy/autoresearch.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "autoresearch",
    "experiment",
    "optimization",
    "benchmark",
    "coding-agent"
  ],
  "license": "MIT",
  "author": "David Cortés <477473+davebcn87@users.noreply.github.com>",
  "homepage": "https://github.com/davebcn87/pi-autoresearch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davebcn87/pi-autoresearch.git"
  },
  "bugs": {
    "url": "https://github.com/davebcn87/pi-autoresearch/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "extensions",
    "skills",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typebox": "^1.1.24"
  }
}
